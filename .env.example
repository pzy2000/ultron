# Use as a template for ~/.ultron/.env (create ~/.ultron if needed).
# Docs: docs/zh/Components/Config.md / docs/zh/GetStarted/Installation.md
#
# Required for DashScope TextEmbedding (maps to UltronConfig.dashscope_api_key):
# DASHSCOPE_API_KEY=your-api-key

# ULTRON_DATA_DIR=~/.ultron
# ULTRON_DB_NAME=ultron.db
# ULTRON_DEFAULT_AGENT=default_agent

# Client workspace (memory_sync): optional; falls back to ULTRON_DEFAULT_AGENT then default_agent
# AGENT_ID=default_agent

# ULTRON_EMBEDDING_BACKEND=dashscope
# ULTRON_EMBEDDING_MODEL=text-embedding-v4
# ULTRON_EMBEDDING_DIMENSION=1024

# For local embedding backend example:
# ULTRON_EMBEDDING_BACKEND=local
# ULTRON_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# IMPORTANT: one ULTRON_DATA_DIR can only use one embedding backend/model/dimension.
# If you switch embedding settings, run reset_all() first.

# OpenAI-compatible LLM settings (defaults keep DashScope-compatible path)
# ULTRON_LLM_PROVIDER=dashscope
# ULTRON_MODEL=qwen3.6-flash
# ULTRON_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ULTRON_API_KEY=your-api-key
#
# Backward-compatible LLM vars (fallbacks):
# ULTRON_LLM_MODEL=qwen3.6-flash
# ULTRON_LLM_API_URL=https://dashscope.aliyuncs.com/api/v1
# ULTRON_MEMORY_CATEGORY_MODEL=qwen3.6-flash
# ULTRON_SKILL_CATEGORY_MODEL=qwen3.6-flash
# ULTRON_LLM_MAX_INPUT_TOKENS=200000
# ULTRON_LLM_PROMPT_RESERVE_TOKENS=8192
# ULTRON_LLM_TOKEN_COUNT_ENCODING=cl100k_base
# ULTRON_LLM_REQUEST_TIMEOUT=600
# ULTRON_LLM_MAX_RETRIES=2
# ULTRON_LLM_RETRY_BASE_DELAY=1.0

# Model router function (disabled by default; not an assistant provider)
# ULTRON_ROUTER_ENABLED=0
# ULTRON_ROUTER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ULTRON_ROUTER_MODEL=qwen3.6-plus
# ULTRON_ROUTER_API_KEY=

# ULTRON_HOT_PROMOTION_THRESHOLD=3
# ULTRON_HOT_DECAY_HOTNESS=0.1
# ULTRON_WARM_DECAY_HOTNESS=0.01
# ULTRON_WARM_MAX_ENTRIES=1000
# ULTRON_COLD_TTL_DAYS=30
# ULTRON_HOT_SELECT_COUNT=3
# ULTRON_DEDUP_SIMILARITY_THRESHOLD=0.85

# ULTRON_MEMORY_MERGE_MAX_FIELD_TOKENS=8192

# ULTRON_L0_MAX_TOKENS=64
# ULTRON_L1_MAX_TOKENS=256

# ULTRON_ENABLE_INTENT_ANALYSIS=1
# ULTRON_MEMORY_SEARCH_LIMIT=10
# ULTRON_SKILL_SEARCH_LIMIT=5
# ULTRON_ASYNC_EMBEDDING=0
# ULTRON_EMBEDDING_QUEUE_SIZE=100
# ULTRON_EMBEDDING_QUEUE_WORKERS=2

# ULTRON_DECAY_INTERVAL_HOURS=6.0
# ULTRON_DECAY_ALPHA=0.05
# ULTRON_TIME_DECAY_WEIGHT=0.1

# HTTP server only (not UltronConfig): ULTRON_LOG_LEVEL=INFO
# ULTRON_RESET_TOKEN=

# Authentication (JWT): auto-generated and persisted to ~/.ultron/.jwt_secret if not set
# ULTRON_JWT_SECRET=
# ULTRON_JWT_EXPIRE_HOURS=24

# Remote backup export (GET /backup/export): if set, clients pass X-Ultron-Backup-Token or ?token=
# ULTRON_BACKUP_TOKEN=

# In-process local tar backups (Docker-friendly; mount ULTRON_LOCAL_BACKUP_DIR to a separate volume)
# ULTRON_LOCAL_BACKUP_ENABLED=0
# ULTRON_LOCAL_BACKUP_DIR=/var/ultron-local-backups
# ULTRON_LOCAL_BACKUP_INTERVAL_HOURS=24
# ULTRON_LOCAL_BACKUP_RETAIN_DAYS=14

